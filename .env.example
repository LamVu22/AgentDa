# Canvas LMS
# Your school's Canvas URL — no trailing slash
CANVAS_BASE_URL=https://your-school.instructure.com

# Personal access token from Canvas
# Canvas -> Account -> Settings -> Approved Integrations -> New Access Token
CANVAS_API_TOKEN=your_canvas_token_here

# The exact term name as it appears in Canvas
# Check by running: python test_courses.py
CANVAS_TERM=Spring Semester 2026


# OpenAI
# Get your key at platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# Model to use — gpt-4o-mini is recommended for cost and speed
OPENAI_MODEL=gpt-4o-mini


# Ollama (optional — use instead of OpenAI for fully local setup)
# Make sure ollama serve is running before starting
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b


# Planning settings
# How many days ahead to plan
PLANNING_HORIZON_DAYS=14

# Maximum study hours per day
MAX_STUDY_HOURS_PER_DAY=4

# Days of the week to skip — 0=Monday, 6=Sunday
# Example: 5,6 blocks Saturday and Sunday
# Leave blank to plan every day
BLOCKED_DAYS=
